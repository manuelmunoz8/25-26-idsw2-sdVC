@startuml abrirConvocatoria-analisis
skinparam backgroundColor white
skinparam shadowing false
skinparam DefaultFontColor black
skinparam DefaultFontSize 12
skinparam linetype polyline

rectangle #CDEBA5 "CONVOCATORIAS_ABIERTAS" as ConvocatoriasAbiertas
rectangle #CDEBA5 "CONVOCATORIA_ABIERTA" as ConvocatoriaAbierta

package abrirConvocatoria as "abrirConvocatoria()" {
    rectangle #629EF9 <<Boundary>> DetalleConvocatoriaView
    rectangle #b5bd68 <<Control>> ConvocatoriaController
    rectangle #F2AC4E <<Entity>> ConvocatoriaRepository
    rectangle #F2AC4E <<Entity>> Convocatoria
}

rectangle #CDEBA5 ":Collaboration ImportarConvocatoria" as ImportarConvocatoria
rectangle #CDEBA5 ":Collaboration AbrirConvocatorias" as AbrirConvocatorias

ConvocatoriasAbiertas -r-> DetalleConvocatoriaView: abrirConvocatoria(convocatoriaId)

DetalleConvocatoriaView -d-> ConvocatoriaController: obtenerDetalleConvocatoria(convocatoriaId) : Convocatoria
ConvocatoriaController -d-> ConvocatoriaRepository: obtenerPorId(convocatoriaId) : Convocatoria
ConvocatoriaRepository -- Convocatoria

DetalleConvocatoriaView ..> ImportarConvocatoria: importarConvocatoria()
DetalleConvocatoriaView ..> AbrirConvocatorias: abrirConvocatorias()

DetalleConvocatoriaView ..> ConvocatoriaAbierta: <<finalizar>>

@enduml
