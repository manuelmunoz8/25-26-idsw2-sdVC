{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "shared-dtos": ["../dtos"],
      "shared-dtos/*": ["../dtos/*"]
    },
    "ignoreDeprecations": "6.0",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "..",
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "../dtos/**/*"],
  "exclude": ["node_modules", "dist"]
}
