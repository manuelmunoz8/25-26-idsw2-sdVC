@startuml abrirOpcionesCargaTrabajo-diseño
skinparam style strictuml

actor "Usuario" as user
participant "OpcionesCargaTrabajoView" as view
participant "CargaTrabajoController" as controller
participant "Sesion" as sesion
participant "InvestigadorRepository" as repo

user -> view : abrirOpcionesCargaTrabajo()
activate view
view -> controller : cargarCargaTrabajo()
activate controller
controller -> sesion : getUsuarioActual()
activate sesion
sesion --> controller : usuario
deactivate sesion
controller -> repo : obtenerCargaTrabajo(investigadorId)
activate repo
repo --> controller : Investigador
deactivate repo
controller --> view : CargaTrabajo
deactivate controller
view --> user : mostrarOpcionesCargaTrabajo()
deactivate view
@enduml
