@startuml editarPerfil
skinparam style strictuml

actor InvestigadorUsuario as User
participant "EditarPerfilView" as View
participant "EditarPerfilController" as Controller
participant "Sesion" as Sesion
participant "UsuarioRepository" as Repository

User -> View: solicita editar perfil
activate View
View -> Controller: cargarDatosActuales()
activate Controller
Controller -> Sesion: getUsuarioActual()
activate Sesion
Sesion --> Controller: usuario
deactivate Sesion
Controller -> Repository: obtenerPorId(usuario.id)
activate Repository
Repository --> Controller: usuarioCompleto
deactivate Repository
Controller --> View: datosActuales
deactivate Controller
View --> User: muestra datos
User -> View: solicita guardar cambios
View -> Controller: guardarCambios(datosNuevos)
activate Controller
Controller -> Repository: actualizar(usuarioModificado)
activate Repository
Repository --> Controller: true
deactivate Repository
Controller --> View: true
deactivate Controller
View --> User: confirma actualizacion
deactivate View
@enduml
