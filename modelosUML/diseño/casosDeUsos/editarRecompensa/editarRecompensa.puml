@startuml editarRecompensa
skinparam style strictuml
actor Usuario
participant "EditarRecompensaView" as View
participant "RecompensaController" as Controller
participant "RecompensaRepository" as Repo
database "Database" as DB

Usuario -> View: editarRecompensa()
View -> Controller: cargarDatosActuales()
Controller -> Repo: obtenerPorId(recompensaId)
Repo -> DB: SELECT * FROM Recompensa
DB --> Repo: Recompensa
Repo --> Controller: Recompensa
Controller --> View: DatosRecompensa

Usuario -> View: guardarCambios(datosNuevos)
View -> Controller: guardarCambios(datosNuevos)
Controller -> Repo: actualizar(recompensa)
Repo -> DB: UPDATE Recompensa
DB --> Repo: success
Repo --> Controller: true
Controller --> View: true

View -> Usuario: confirmar()
@enduml
